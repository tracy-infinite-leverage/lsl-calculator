# Copy to .env.local and fill in real values. Never commit .env or .env.local.

# === Anthropic Claude API (Phase 3: PDF extraction) ===
# Required for /api/extract-pdf. Default vendor per OQ-B sign-off: Anthropic
# Claude API, no-retention enterprise tier. Generate at console.anthropic.com.
ANTHROPIC_API_KEY=

# === Supabase (Phase 7: optional logins; not used in Phases 1-6) ===
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# === Transactional email (optional) ===
RESEND_API_KEY=
BREVO_API_KEY=
