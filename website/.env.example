# LSL Platform — environment variables
#
# Copy this file to `.env.local` (gitignored) and fill in real values for local dev.
# Production + Preview values are set in Vercel (see Task 3.3 of the auth plan).
# Never commit real secrets — the `.env*` glob is in `website/.gitignore`.

# ─────────────────────────────────────────────────────────────────────────────
# Supabase — LSL platform auth (E5.1 auth slice)
# ─────────────────────────────────────────────────────────────────────────────
# Project: `lsl-platform` (ref: woxtujkxatosbirikxtq, region: ap-southeast-2, plan: Pro)
# Dashboard: https://supabase.com/dashboard/project/woxtujkxatosbirikxtq
#
# Get URL + anon key via the account-scoped Supabase MCP
# (mcp__2ac7599f-...__get_project_url / __get_publishable_keys)
# or from the Supabase dashboard → Settings → API.

# Project API URL — safe to expose (NEXT_PUBLIC_*).
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Anon / publishable key — safe to expose (NEXT_PUBLIC_*).
# This is the client-side key. RLS is the security boundary.
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Service-role key — SERVER-SIDE ONLY. Bypasses RLS. Never expose to the browser,
# never log, never commit. Used by the `handle_new_user` trigger only via SECURITY
# DEFINER (in-database), and by the `purge-expired-orgs` Edge Function via env.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here-DO-NOT-COMMIT

# ─────────────────────────────────────────────────────────────────────────────
# Auth — redirect URL fallback (E5.1 auth slice)
# ─────────────────────────────────────────────────────────────────────────────
# Hardcoded production-domain fallback used by `buildAuthRedirectUrl` when the
# request `Origin` header is missing. Without this, a missing Origin in
# production silently degrades to a localhost link in customer verification +
# password-reset emails.
#
# MUST be set to the production domain in Vercel Production env. Leave UNSET
# in Vercel Preview env (each preview should use its own origin) and Vercel
# Development env. For local `npm run dev`, leave unset so localhost stays as
# the final fallback.
#
# See: src/lib/auth/redirect-url.ts (helper) + docs/engineering/vercel-config.md
NEXT_PUBLIC_SITE_URL=https://www.lslcalculator.com.au

# ─────────────────────────────────────────────────────────────────────────────
# Feature flags — bulk-summary PDF download CTA (E6.4 Task 4.6, G-5)
# ─────────────────────────────────────────────────────────────────────────────
# Gates the "Download bulk summary PDF" CTA on the multi-employee bulk results
# screen. Strict-string contract: only the literal `'true'` enables the CTA.
# See: src/lib/feature-flags.ts.
#
# Phase 5a (E6.6a Task 6.3, 2026-06-02): flipped from `false` to `true`. The
# real bulk PDF endpoint (`POST /api/reports/bulk-summary`) now ships with
# the SingleEmployee + BulkSummary templates dispatched server-side. Set this
# to `false` only if you need to hide the bulk CTA for a specific environment
# (e.g. a staging branch where the dispatcher is temporarily broken).
#
# This flag does NOT gate the single-employee CTA — that ships unconditionally
# against the canonical `/api/reports/single-employee` endpoint (Task 6.3
# swapped it from the legacy `/api/export-pdf`).
NEXT_PUBLIC_PDF_DOWNLOAD_ENABLED=true
